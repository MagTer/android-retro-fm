<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature
        android:name="android.hardware.type.automotive"
        android:required="true" />

    <application
        android:name="com.retrofm.android.RetroFmApplication"
        android:allowBackup="true"
        android:appCategory="audio"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="false"
        tools:targetApi="36">

        <meta-data
            android:name="com.android.automotive"
            android:resource="@xml/automotive_app_desc" />

        <!-- Cast is gated off in the car (FEATURE_AUTOMOTIVE never builds a CastPlayer), but
             media3-cast pulls play-services-cast-framework transitively through :core, which
             merges these entries in. The com.google.android.gms.version meta-data makes head
             units without a current Google Play services show a "needs Google Play services"
             error on launch — strip it and the dead cast components from the car artifact. -->
        <meta-data
            android:name="com.google.android.gms.version"
            tools:node="remove" />
        <receiver
            android:name="com.google.android.gms.cast.framework.media.MediaIntentReceiver"
            tools:node="remove" />
        <service
            android:name="com.google.android.gms.cast.framework.ReconnectionService"
            tools:node="remove" />
    </application>
</manifest>
