<resources>
    <!-- AppCompat parent is required: the mediarouter cast chooser/controller dialogs
         inflate against AppCompat attributes and crash under a platform theme. The visible
         UI is 100% Compose, so this changes nothing on screen. -->
    <style name="Theme.RetroFM" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/brand_dark_blue</item>
        <item name="android:navigationBarColor">@color/brand_dark_blue</item>
        <item name="android:windowBackground">@color/brand_dark_blue</item>
    </style>

    <!-- Tints the MediaRouteButton light so it stays visible on the dark artwork background. -->
    <style name="ThemeOverlay.RetroFM.MediaRoute" parent="">
        <item name="mediaRouteButtonTint">@color/white</item>
    </style>
</resources>
